# ============================================================
# alphinium-app react-native — Environment Variables
# Copy this file to .env and fill in your values.
# All vars MUST have EXPO_PUBLIC_ prefix to be available in the client bundle.
#
# Forge template: this file is customised per-project by the build agent.
# Run `alphinium forge build ios` / `alphinium forge build android` to trigger builds.
# ============================================================

# ── Backend API (CMS / Strapi) ─────────────────────────────
# Production Strapi pod (set by Alphinium at project creation):
EXPO_PUBLIC_API_URL=
# Local dev:
# EXPO_PUBLIC_API_URL=http://localhost:1337

# API bearer token (optional — only required if Strapi content is restricted)
EXPO_PUBLIC_API_TOKEN=

# ── Stripe ────────────────────────────────────────────────
# Publishable key — safe to commit (this is the test key placeholder)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# ── App Branding ──────────────────────────────────────────
# Set by Alphinium forge at project creation — override for local dev
EXPO_PUBLIC_APP_NAME=My App

# Deep link scheme (must match app.json > scheme)
EXPO_PUBLIC_APP_SCHEME=myapp

# ── OAuth Login Providers ─────────────────────────────────
# Comma-separated list of enabled login providers.
# Valid values: github, google, facebook, email
# github   — good for developer-facing apps
# google   — universal, works for consumer apps
# facebook — consumer/social apps
# email    — shows "Sign in with Email" option (currently placeholder)
EXPO_PUBLIC_OAUTH_PROVIDERS=github,google,email

# ── Push Notifications (optional) ────────────────────────
# Expo push token is generated automatically. Set your own push server URL:
# EXPO_PUBLIC_PUSH_SERVER_URL=https://api.yourapp.com/notifications

# ── Firebase App Distribution (optional) ─────────────────
# Used by alphinium-mac-build-agent for Android beta distribution.
# Leave empty if not using Firebase distribution.
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=

